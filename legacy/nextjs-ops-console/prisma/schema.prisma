// =====================================================================
// cms_marketing_auto — Prisma schema (SQLite for local/demo, Postgres in prod)
// Single source of truth for the data model described in the MVP PRD.
//
// NOTE: This project runs on SQLite so it is fully self-contained (no external
// DB server needed) for local dev and demos. Enums in the original Postgres
// design are modelled as plain `String` columns with documented default values;
// array columns are stored as JSON strings. To deploy against PostgreSQL,
// switch `provider` back to "postgresql" and restore the enum/array types
// (see README → Deployment).
//
// Run:  npm run prisma:generate && npm run prisma:dbpush
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ----------------------------- Users / Orgs --------------------------

model User {
  id           String   @id @default(cuid())
  name         String
  username     String?  @unique // 登录账号名（与 email 二选一）
  email        String   @unique
  phone        String?
  passwordHash String
  status       String   @default("active") // active | disabled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  OrganizationMember[]
  apiKeys      ApiKey[]
  userPermissions UserPermission[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("active") // active | disabled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          OrganizationMember[]
  contacts         Contact[]
  customFields     CustomField[]
  customFieldValues CustomFieldValue[]
  events           Event[]
  tags             Tag[]
  segments         Segment[]
  templates        Template[]
  campaigns        Campaign[]
  sendTasks        SendTask[]
  sendLogs         SendLog[]
  workflows        Workflow[]
  apiKeys          ApiKey[]
  webhooks         Webhook[]
  importJobs       ImportJob[]
  systemLogs       SystemLog[]
  userPermissions  UserPermission[]
  autoTagRules     AutoTagRule[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("MARKETING_OPERATOR") // SUPER_ADMIN | ORG_ADMIN | MARKETING_OPERATOR | VIEWER
  status         String   @default("active")             // active | disabled
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// ----------------------------- Contacts ------------------------------

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  name           String?
  email          String?
  phone          String?
  company        String?
  country        String?
  city           String?
  language       String?
  source         String?
  status         String   @default("active") // active | unsubscribed | bounced | blacklisted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActiveAt   DateTime?

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events         Event[]
  contactTags    ContactTag[]
  contactSegments ContactSegment[]
  sendLogs       SendLog[]
  channels       ContactChannel[]

  @@unique([organizationId, email])
  @@unique([organizationId, phone])
  @@index([organizationId, status])
  @@index([organizationId, email])
  @@index([organizationId, phone])
}

model CustomField {
  id            String   @id @default(cuid())
  organizationId String
  entityType    String   @default("contact") // contact | campaign | event
  fieldKey      String
  fieldLabel    String
  fieldType     String   @default("text") // text | number | date | boolean | select | multi_select
  options       String?   // JSON 字符串：自定义字段选项
  required      Boolean  @default(false)
  enabled       Boolean  @default(true)
  sortOrder     Int      @default(0)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values       CustomFieldValue[]

  @@unique([organizationId, entityType, fieldKey])
  @@index([organizationId, entityType])
}

model CustomFieldValue {
  id            String   @id @default(cuid())
  organizationId String
  entityType    String
  entityId      String
  fieldId       String
  value         String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  field        CustomField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType, entityId])
  @@index([fieldId])
}

// ----------------------------- Events --------------------------------

model Event {
  id             String    @id @default(cuid())
  organizationId String
  contactId      String?
  eventName      String
  eventType      String    @default("CUSTOM") // REGISTER | LOGIN | BROWSE | OPEN_EMAIL | CLICK_LINK | PURCHASE | REFUND | UNSUBSCRIBE | SENT_EMAIL | CUSTOM
  source         String?
  properties     String?   // JSON 字符串
  occurredAt     DateTime
  receivedAt     DateTime  @default(now())
  dedupKey       String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([dedupKey])
  @@index([organizationId, contactId])
  @@index([organizationId, eventType])
}

// ----------------------------- 自动打标签规则 (AutoTagRule) -----------
// 规则引擎（非 AI）：事件触发（计数/即时）+ 不活跃定时扫描，命中即给联系人打标。

model AutoTagRule {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  enabled        Boolean  @default(true)
  trigger        String   // EVENT | INACTIVITY
  eventType      String?  // EVENT 触发匹配的事件类型，如 BROWSE / CLICK_LINK / PURCHASE
  matchMode      String   @default("always") // always | count
  threshold      Int      @default(1)        // count 模式阈值（如浏览 2 次）
  windowDays     Int?     // 统计窗口（天），null=不限
  propMatch      String?  // JSON: {"field":"page","contains":"f1"} 可选属性过滤
  tagTemplate    String   // 标签名模板，支持 {var} 取自 properties，如 purchased_{product}
  inactiveDays   Int?     // INACTIVITY 触发：多少天未活跃
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, enabled])
}

// ----------------------------- Tags / Segments -----------------------

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String?
  description    String?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactTags  ContactTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ContactTag {
  id         String @id @default(cuid())
  contactId  String
  tagId      String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([tagId])
}

model Segment {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String   @default("dynamic") // static | dynamic
  rules          String?    // 动态分群规则 JSON 字符串 (见 docs)
  description    String?

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactSegments ContactSegment[]
  campaigns    Campaign[]

  @@unique([organizationId, name]) // 分组名称不能重复
  @@index([organizationId])
}

model ContactSegment {
  id         String @id @default(cuid())
  contactId  String
  segmentId  String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([contactId, segmentId])
  @@index([segmentId])
}

// ----------------------------- Templates / Campaigns -----------------

model Template {
  id             String   @id @default(cuid())
  organizationId String
  type           String   // EDM | SMS
  name           String
  subject        String?  // EDM
  body           String   // html (EDM) 或纯文本 (SMS)
  variables      String   @default("[]") // JSON 数组，如 ["first_name","city"]
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]
  sendTasks    SendTask[]

  @@index([organizationId, type])
}

model Campaign {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  objective      String?
  segmentId      String?
  channel        String   // EMAIL | SMS | WHATSAPP | ... （主渠道，兼容旧逻辑）
  templateId     String?  // 主模板，兼容旧逻辑
  // ---- 扩展字段（多渠道 / 圈人 / 落地页）----
  activity       String?  // 活动 / IP
  country        String?  // 目标国家
  language       String?  // 目标语言
  channels       String?  // JSON: ["EMAIL","SMS"]
  edmTemplateId  String?  // EDM 模板 id
  smsTemplateId  String?  // SMS 模板 id
  landingPageId  String?  // 落地页（LANDING 模板）id
  landingUrl     String?  // 跳转链接（无落地页时回退）
  audienceType   String?  // segment | tags | sql
  tagIds         String?  // JSON: ["tagId1","tagId2"]
  sqlQuery       String?  // SQL 圈人语句
  status         String   @default("draft") // draft | scheduled | sending | sent | paused | failed | completed
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     Template?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  segment      Segment?     @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  sendTasks    SendTask[]

  @@index([organizationId, status])
}

model SendTask {
  id             String   @id @default(cuid())
  organizationId String
  campaignId     String?
  channel        String
  templateId     String?  // 该批次使用的模板（多渠道时按渠道区分）
  status         String   @default("queued") // queued | sending | success | failed | skipped
  totalCount     Int      @default(0)
  successCount   Int      @default(0)
  failedCount    Int      @default(0)
  createdAt      DateTime @default(now())
  finishedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  template     Template?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  logs         SendLog[]

  @@index([organizationId, campaignId])
}

model SendLog {
  id             String   @id @default(cuid())
  organizationId String
  taskId         String
  contactId      String?
  channel        String
  provider       String?  // 实际使用的 provider，如 smtp / twilio / mock
  status         String   // queued | sending | success | failed | skipped
  errorMessage   String?
  messageId      String?  // provider 返回的消息ID，用于打开/点击回执
  sentAt         DateTime?

  task         SendTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  contact      Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([contactId, channel])
}

// ----------------------------- Multi-channel -------------------------

model ContactChannel {
  id             String   @id @default(cuid())
  contactId      String
  channel        String
  identifier     String   // 该渠道的标识，如 whatsapp 号码 / app user id
  verified       Boolean  @default(false)
  consentStatus  String   @default("unknown") // unknown | granted | revoked
  createdAt      DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, channel, identifier])
  @@index([contactId])
}

// ----------------------------- Workflows -----------------------------

model Workflow {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  definition     String   // JSON 字符串：触发器/条件/动作/延迟/分支 DAG
  enabled        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ----------------------------- Import jobs ---------------------------

model ImportJob {
  id             String   @id @default(cuid())
  organizationId String
  fileName       String
  entityType     String   @default("contact") // contact | campaign | event
  status         String   @default("queued")  // queued | sending | success | failed | skipped
  totalCount     Int      @default(0)
  successCount   Int      @default(0)
  failedCount    Int      @default(0)
  duplicateCount Int      @default(0)
  report         String?   // JSON 字符串：错误明细
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ----------------------------- Integrations / Logs -------------------

model ApiKey {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  name           String
  keyHash        String   @unique
  prefix         String   // 展示用前缀，如 cms_live_
  scopes         String   @default("[\"read\"]") // JSON 数组，如 ["read","write"]
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  events         String   @default("[]") // JSON 数组，订阅的事件类型
  secret         String   // 签名密钥
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model SystemLog {
  id             String   @id @default(cuid())
  organizationId String?
  type           String   // OPERATION | API | WEBHOOK | SEND | ERROR
  actorId        String?
  action         String
  target         String?
  request        String?
  response       String?
  errorStack     String?  // 仅管理员可见
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
  @@index([createdAt])
}

// ----------------------------- Settings (KV) -------------------------
// 后台可读写的系统设置（如邮件通道配置），避免修改 .env 后重启。
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ----------------------------- Permissions ---------------------------
// 细粒度权限矩阵：每个组织成员对每个「模块」的每种「操作」是否允许。
// 仅在 requirePermission 中校验；SUPER_ADMIN 始终放行。
// module: contacts|tags|segments|templates|campaigns|settings|users|reports|workflows|events|ai
// action: view|create|edit|delete
model UserPermission {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  module         String
  action         String
  allowed        Boolean  @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, module, action])
  @@index([organizationId, userId])
}
