# =====================================================================
# cms_marketing_auto — Environment Configuration
# Copy to `.env` and fill values. NEVER commit the real `.env`.
# =====================================================================

# ----------------------- Core -----------------------
# JWT secret used to sign session tokens. Generate a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
# Token lifetime, e.g. 7d, 24h
JWT_EXPIRES_IN=7d

# ----------------------- Database (PostgreSQL) -----------------------
# Use the managed DB in prod. For local dev you can also use a dockerized PG.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cms_mkt?schema=public"

# ----------------------- Queue / Cache (Redis) -----------------------
# Required only when QUEUE_DRIVER=bullmq (the production path).
# In dev you can use QUEUE_DRIVER=memory and omit Redis.
REDIS_URL="redis://localhost:6379"
QUEUE_DRIVER=memory            # memory | bullmq

# ----------------------- Email provider (3rd-party OSS seam) ---------
# mock   -> logs to console, no real send (default for dev)
# smtp   -> uses nodemailer + your SMTP server (open-source)
# ses    -> AWS SDK (需要 aws-sdk v3)
# sendgrid -> @sendgrid/mail SDK
EMAIL_PROVIDER=mock
EMAIL_FROM="Marketing <noreply@example.com>"
# --- smtp ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# --- ses (stub) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# --- sendgrid (stub) ---
SENDGRID_API_KEY=

# ----------------------- SMS provider (3rd-party OSS seam) -----------
# mock | twilio | vonage | aliyun | tencent
SMS_PROVIDER=mock
# --- twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# --- vonage ---
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM=
# --- aliyun (stub) ---
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ----------------------- Storage (S3-compatible, 3rd-party OSS seam) -
# mock | s3
STORAGE_PROVIDER=mock
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ENDPOINT=           # for MinIO / 兼容 S3 的自建存储
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ----------------------- AI provider (3rd-party OSS seam) ------------
# mock | openai | anthropic | ollama
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OLLAMA_BASE_URL=http://localhost:11434

# ----------------------- AI Crawler (合规受限模块) --------------------
# 默认关闭！该模块涉及数据采集，必须人工开启并配置合规白名单。
CRAWLER_ENABLED=false
CRAWLER_PROVIDER=mock        # mock | playwright | apify
