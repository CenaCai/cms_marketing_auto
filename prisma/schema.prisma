// =====================================================================
// cms_marketing_auto — Prisma schema (PostgreSQL)
// Single source of truth for the data model described in the MVP PRD.
// Run:  npm run prisma:generate && npm run prisma:migrate
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- Enums ---------------------------------

enum UserStatus {
  active
  disabled
}

enum MemberRole {
  SUPER_ADMIN
  ORG_ADMIN
  MARKETING_OPERATOR
  VIEWER
}

enum ContactStatus {
  active
  unsubscribed
  bounced
  blacklisted
}

enum Channel {
  EMAIL
  SMS
  WHATSAPP
  FACEBOOK
  TELEGRAM
  X
  APP_PUSH
  INSTAGRAM_DM
  LINE
  WECHAT
  PHONE
}

enum FieldType {
  text
  number
  date
  boolean
  select
  multi_select
}

enum EntityType {
  contact
  campaign
  event
}

enum EventType {
  REGISTER
  LOGIN
  BROWSE
  PURCHASE
  REFUND
  CUSTOM
}

enum TemplateType {
  EDM
  SMS
}

enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  paused
  failed
  completed
}

enum SegmentType {
  static
  dynamic
}

enum SendStatus {
  queued
  sending
  success
  failed
  skipped
}

enum ConsentStatus {
  unknown
  granted
  revoked
}

enum LogType {
  OPERATION
  API
  WEBHOOK
  SEND
  ERROR
}

// ----------------------------- Users / Orgs --------------------------

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  passwordHash String
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberships  OrganizationMember[]
  apiKeys      ApiKey[]
  sentLogs     SendLog[]              @relation("SendLogOperator")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  status    UserStatus @default(active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          OrganizationMember[]
  contacts         Contact[]
  customFields     CustomField[]
  events           Event[]
  tags             Tag[]
  segments         Segment[]
  templates        Template[]
  campaigns        Campaign[]
  sendTasks        SendTask[]
  sendLogs         SendLog[]
  workflows        Workflow[]
  contactChannels  ContactChannel[]
  apiKeys          ApiKey[]
  webhooks         Webhook[]
  importJobs       ImportJob[]
  systemLogs       SystemLog[]
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(MARKETING_OPERATOR)
  status         UserStatus @default(active)
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// ----------------------------- Contacts ------------------------------

model Contact {
  id             String        @id @default(cuid())
  organizationId String
  name           String?
  email          String?
  phone          String?
  country        String?
  city           String?
  language       String?
  source         String?
  status         ContactStatus @default(active)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lastActiveAt   DateTime?

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customValues   CustomFieldValue[]
  events         Event[]
  contactTags    ContactTag[]
  contactSegments ContactSegment[]
  sendLogs       SendLog[]
  channels       ContactChannel[]

  @@unique([organizationId, email])
  @@unique([organizationId, phone])
  @@index([organizationId, status])
  @@index([organizationId, email])
  @@index([organizationId, phone])
}

model CustomField {
  id            String     @id @default(cuid())
  organizationId String
  entityType    EntityType @default(contact)
  fieldKey      String
  fieldLabel    String
  fieldType     FieldType  @default(text)
  options       Json?
  required      Boolean    @default(false)
  enabled       Boolean    @default(true)
  sortOrder     Int        @default(0)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values       CustomFieldValue[]

  @@unique([organizationId, entityType, fieldKey])
  @@index([organizationId, entityType])
}

model CustomFieldValue {
  id            String     @id @default(cuid())
  organizationId String
  entityType    EntityType
  entityId      String
  fieldId       String
  value         String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  field        CustomField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType, entityId])
  @@index([fieldId])
}

// ----------------------------- Events --------------------------------

model Event {
  id             String    @id @default(cuid())
  organizationId String
  contactId      String?
  eventName      String
  eventType      EventType @default(CUSTOM)
  source         String?
  properties     Json?
  occurredAt     DateTime
  receivedAt     DateTime  @default(now())
  dedupKey       String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([dedupKey])
  @@index([organizationId, contactId])
  @@index([organizationId, eventType])
}

// ----------------------------- Tags / Segments -----------------------

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String?
  description    String?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactTags  ContactTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ContactTag {
  id         String @id @default(cuid())
  contactId  String
  tagId      String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([tagId])
}

model Segment {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  type           SegmentType  @default(dynamic)
  rules          Json?        // 动态分群规则 (见 docs)
  description    String?

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactSegments ContactSegment[]

  @@index([organizationId])
}

model ContactSegment {
  id         String @id @default(cuid())
  contactId  String
  segmentId  String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([contactId, segmentId])
  @@index([segmentId])
}

// ----------------------------- Templates / Campaigns -----------------

model Template {
  id             String        @id @default(cuid())
  organizationId String
  type           TemplateType
  name           String
  subject        String?       // EDM
  body           String        // html (EDM) 或纯文本 (SMS)
  variables      String[]      // 可用变量列表，如 ["first_name","city"]
  version        Int           @default(1)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  @@index([organizationId, type])
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  objective      String?
  segmentId      String?
  channel        Channel
  templateId     String?
  status         CampaignStatus @default(draft)
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     Template?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  segment      Segment?     @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  sendTasks    SendTask[]

  @@index([organizationId, status])
}

model SendTask {
  id             String   @id @default(cuid())
  organizationId String
  campaignId     String?
  channel        Channel
  status         SendStatus @default(queued)
  totalCount     Int      @default(0)
  successCount   Int      @default(0)
  failedCount    Int      @default(0)
  createdAt      DateTime @default(now())
  finishedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  logs         SendLog[]

  @@index([organizationId, campaignId])
}

model SendLog {
  id             String     @id @default(cuid())
  organizationId String
  taskId         String
  contactId      String?
  channel        Channel
  provider       String?    // 实际使用的 provider，如 smtp / twilio / mock
  status         SendStatus
  errorMessage   String?
  messageId      String?    // provider 返回的消息ID，用于打开/点击回执
  sentAt         DateTime?

  task         SendTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  contact      Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       Event[]    @relation("SendLogEvent")

  @@index([taskId])
  @@index([contactId, channel])
}

// ----------------------------- Multi-channel -------------------------

model ContactChannel {
  id             String        @id @default(cuid())
  contactId      String
  channel        Channel
  identifier     String        // 该渠道的标识，如 whatsapp 号码 / app user id
  verified       Boolean       @default(false)
  consentStatus  ConsentStatus @default(unknown)
  createdAt      DateTime      @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, channel, identifier])
  @@index([contactId])
}

// ----------------------------- Workflows -----------------------------

model Workflow {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  definition     Json     // 触发器/条件/动作/延迟/分支的 DAG (见 docs + THIRD_PARTY_INTEGRATIONS.md)
  enabled        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ----------------------------- Import jobs ---------------------------

model ImportJob {
  id             String   @id @default(cuid())
  organizationId String
  fileName       String
  entityType     EntityType @default(contact)
  status         SendStatus @default(queued)
  totalCount     Int      @default(0)
  successCount   Int      @default(0)
  failedCount    Int      @default(0)
  duplicateCount Int      @default(0)
  report         Json?    // 错误明细
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ----------------------------- Integrations / Logs -------------------

model ApiKey {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  name           String
  keyHash        String   @unique
  prefix         String   // 展示用前缀，如 cms_live_
  scopes         String[] @default(["read"])
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  events         String[] // 订阅的事件类型
  secret         String   // 签名密钥
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model SystemLog {
  id             String   @id @default(cuid())
  organizationId String?
  type           LogType
  actorId        String?
  action         String
  target         String?
  request        Json?
  response       Json?
  errorStack     String?  // 仅管理员可见
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
  @@index([createdAt])
}
