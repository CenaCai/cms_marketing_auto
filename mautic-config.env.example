# Mautic CSTS 一键搭建 —— 配置模板
# 复制为 mauric-config.env 并填入你的目标机实际值（该文件含密码，已被 .gitignore 忽略，不会入库）
#
# —— 数据库（用于自动建库 + mautic:install）——
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mautic
DB_USER=mautic
DB_PASS=mautic_pass_change_me

# —— 站点 ——
SITE_URL=http://localhost:8080

# —— 管理员（两项都填才会自动跑 mautic:install；留空则走网页安装）——
ADMIN_EMAIL=admin@csts.local
ADMIN_PASS=Csts@2026!

# —— 可选：Mautic 核心版本（默认 7.1.*）——
# MAUTIC_VERSION=7.1.*
